# Copy file này thành .env.local rồi điền giá trị thực
# .env.local không được commit (đã có trong .gitignore)

DATABASE_URL=postgresql+asyncpg://notica:changeme@localhost:5432/notica
APP_ENV=development
LOG_LEVEL=info

# SSO — bỏ comment và điền nếu muốn dev với SSO bật
# SSO_ENABLED=true
# KEYCLOAK_URL=https://your-keycloak
# KEYCLOAK_REALM=your-realm
# KEYCLOAK_CLIENT_ID=notica-frontend
