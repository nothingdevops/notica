# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=notica
POSTGRES_USER=notica
POSTGRES_PASSWORD=changeme        # BẮT BUỘC đổi

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=http://192.168.1.10       # URL truy cập Notica — dùng trong link digest Teams
DISPLAY_TIMEZONE=Asia/Ho_Chi_Minh
LOG_LEVEL=info

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=80

# ── SSO — Keycloak (tùy chọn) ─────────────────────────────────────────────────
# Mặc định tắt. Bật khi có Keycloak và muốn yêu cầu đăng nhập trên management UI.
# Ingestion API (POST /api/v1/alerts) luôn dùng X-Job-Token, không bị ảnh hưởng.
#
# Yêu cầu trên Keycloak client:
#   - Client authentication: Off  (public client)
#   - Standard flow: On
#   - Valid redirect URIs: https://<notica-url>/*
#   - Web Origins: +
#
SSO_ENABLED=false
# KEYCLOAK_URL=https://auth.example.com       # base URL, không có /realms/...
# KEYCLOAK_REALM=notica
# KEYCLOAK_CLIENT_ID=notica-frontend
# KEYCLOAK_ISSUER=                            # để trống = tự derive từ URL + realm
# KEYCLOAK_REQUIRED_ROLE=notica-user         # realm role bắt buộc; để trống = không check role
